---
import type { VisualAsset } from "../data/projects";
import VisualAssetFrame from "./VisualAssetFrame.astro";

interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  image: VisualAsset;
}

const { eyebrow, title, text, image } = Astro.props;
---

<section class="section-divider-media reveal">
  <div class="container">
    <div class="section-divider-shell" data-scene>
      <div class="section-divider-image">
        <VisualAssetFrame
          asset={image}
          surface="divider"
          widths={[960, 1280, 1600, 2200]}
          sizes="100vw"
          quality={86}
        />
      </div>
      <div class="section-divider-copy" data-parallax-layer data-depth="0.04">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        <h2>{title}</h2>
        <p>{text}</p>
      </div>
    </div>
  </div>
</section>
