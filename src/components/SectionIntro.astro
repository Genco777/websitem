---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  align?: "left" | "center";
}

const { eyebrow, title, text, align = "left" } = Astro.props;
---

<div class:list={["section-intro", align === "center" && "is-center"]}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2>{title}</h2>
  {text && <p>{text}</p>}
</div>
