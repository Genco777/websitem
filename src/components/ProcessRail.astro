---
import type { ProcessStep } from "../data/site";

interface Props {
  eyebrow?: string;
  title?: string;
  text?: string;
  steps: ProcessStep[];
}

const { eyebrow, title, text, steps } = Astro.props;
---

<section class="process-rail-section reveal">
  <div class="container">
    {(eyebrow || title || text) && (
      <div class="section-intro">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        {title && <h2>{title}</h2>}
        {text && <p>{text}</p>}
      </div>
    )}

    <div class="process-rail">
      {steps.map((item) => (
        <article class="process-step-card">
          <span class="process-step-number">{item.step}</span>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
