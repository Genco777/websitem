---
import { getVisualAssetCollection, type VisualAsset } from "../data/projects";
import VisualAssetFrame from "./VisualAssetFrame.astro";

interface Props {
  eyebrow?: string;
  title?: string;
  text?: string;
  assets: VisualAsset[];
}

const { eyebrow, title, text, assets } = Astro.props;
const collectionLabels = {
  website: "Website",
  branding: "Branding",
  print: "Print",
  local: "Lokal",
  divider: "Leitmotiv",
  mosaic: "Mosaik"
} as const;
---

<section class="latest-work-band reveal">
  <div class="container">
    {(eyebrow || title || text) && (
      <div class="section-intro">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        {title && <h2>{title}</h2>}
        {text && <p>{text}</p>}
      </div>
    )}

    <div class="latest-work-grid" data-scene>
      {assets.map((asset, index) => (
        <article class="latest-work-card" data-parallax-layer data-depth={String(0.02 + index * 0.01)}>
          <VisualAssetFrame
            asset={asset}
            surface="latest-work"
            widths={[520, 760, 1040, 1440]}
            sizes="(max-width: 760px) 100vw, (max-width: 1180px) 50vw, 25vw"
            quality={84}
          />
          <div class="latest-work-meta">
            <span class="small-label">{collectionLabels[getVisualAssetCollection(asset)]}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
