---
import type { VisualAsset } from "../data/projects";
import VisualAssetFrame from "./VisualAssetFrame.astro";

interface Props {
  eyebrow?: string;
  title?: string;
  text?: string;
  images: VisualAsset[];
  maxItems?: number;
}

const { eyebrow, title, text, images, maxItems = 4 } = Astro.props;
const galleryImages = images.slice(0, maxItems);
---

<section class="project-gallery reveal">
  <div class="container">
    {(eyebrow || title || text) && (
      <div class="section-intro">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        {title && <h2>{title}</h2>}
        {text && <p>{text}</p>}
      </div>
    )}

    <div class="project-gallery-grid" data-scene>
      {galleryImages.map((image, index) => (
        <article class:list={["project-gallery-card", index === 0 && "is-wide"]} data-parallax-layer data-depth={String(0.03 + index * 0.01)}>
          <VisualAssetFrame
            asset={image}
            surface={index === 0 ? "gallery-wide" : "gallery"}
            widths={[640, 960, 1280, 1440]}
            sizes={index === 0 ? "(max-width: 760px) 100vw, (max-width: 1180px) 100vw, 62vw" : "(max-width: 760px) 100vw, (max-width: 1180px) 50vw, 31vw"}
            quality={82}
          />
        </article>
      ))}
    </div>
  </div>
</section>
