---
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ContextualCTA from "../components/ContextualCTA.astro";
import PageShowcaseHero from "../components/PageShowcaseHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SelectiveComparison from "../components/SelectiveComparison.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { createBreadcrumbSchema, createServiceSchema } from "../utils/seo";
import { createContactHref, createWhatsappHref } from "../data/site";
import { curateVisualAssets, getProjectAssetsByIds, getProjectBySlug, getVisualAssetById } from "../data/projects";

const breadcrumbs = [
  { name: "Start", href: "/" },
  { name: "Über Fly & Froth", href: "/ueber-fly-froth" }
];

const caremobil = getProjectBySlug("caremobil-greiz")!;
const conner = getProjectBySlug("conner-exteriors")!;
const reinigung = getProjectBySlug("reinigung-hd")!;
const meCon = getProjectBySlug("me-con")!;

const heroAssets = curateVisualAssets(
  [
    ...getProjectAssetsByIds(conner, ["conner-brand-applications-grid", "conner-logo-after"]),
    getVisualAssetById("showcase-brand-business-card")!,
    ...getProjectAssetsByIds(meCon, ["me-con-flyer-overview"])
  ],
  { count: 3, preferredVariants: ["print_mockup", "detail_crop", "square_original", "wide_banner", "device_mockup"] }
);

const comparisonItems = [
  {
    title: "Wertigkeit durch Klarheit",
    text: "Die Projekte gewinnen nicht durch Effekte, sondern durch bessere Hierarchie, bessere Anwendungen und mehr Ordnung in den Kontaktflächen.",
    before: getProjectAssetsByIds(caremobil, ["caremobil-before-desktop"])[0],
    after: getProjectAssetsByIds(caremobil, ["caremobil-after-desktop"])[0]
  },
  {
    title: "Design, das im Alltag trägt",
    text: "Auch Printflächen zeigen denselben Anspruch: weniger Lärm, mehr Lesbarkeit und ein professionellerer Gesamteindruck.",
    before: getProjectAssetsByIds(reinigung, ["reinigung-flyer-before-slide"])[0],
    after: getProjectAssetsByIds(reinigung, ["reinigung-final-mockup"])[0]
  }
];

const whatsappHref = createWhatsappHref("Hallo Fly & Froth, ich möchte eine Zusammenarbeit anfragen.");
---

<BaseLayout
  title="Über Fly & Froth | Karben"
  description="Über Fly & Froth: Studio aus Karben für Marke, Website und strukturierte Systeme im Rhein-Main-Gebiet."
  pathname="/ueber-fly-froth"
  schema={[
    createBreadcrumbSchema(breadcrumbs),
    createServiceSchema("Über Fly & Froth", "Studio für Marke, Website und Systeme.")
  ]}
>
  <Breadcrumbs items={breadcrumbs} />

  <PageShowcaseHero
    eyebrow="Über Fly & Froth"
    title="Ein Studio, das Qualität nicht über Lautstärke, sondern über Auswahl, Ordnung und Konsequenz aufbaut."
    text="Fly & Froth arbeitet für Unternehmen, die digital und visuell hochwertiger auftreten wollen, ohne in generische Agenturästhetik oder Freelancer-Zufall zu rutschen."
    images={heroAssets}
    tone="light"
    layout="brand"
    badges={["No Stock", "Only Own Work"]}
  >
    <div class="grid-1 reveal">
      <article class="proof-card">
        <h3>Website, Brand und Print greifen zusammen</h3>
        <p>Die Leistungen werden nicht isoliert gedacht, sondern als ein durchgehendes System mit klarer visueller Haltung.</p>
      </article>
      <article class="proof-card">
        <h3>Direkte Verantwortung ohne Show</h3>
        <p>Die Arbeit ist bewusst nah an der Umsetzung, ohne aus der Website eine persönliche Selbstdarstellung zu machen.</p>
      </article>
      <article class="proof-card">
        <h3>Regional anschlussfähig, gestalterisch über Standard</h3>
        <p>Karben, Frankfurt und Rhein-Main sind reale Marktkontexte. Der Anspruch liegt sichtbar über dem lokalen Durchschnitt.</p>
      </article>
    </div>
  </PageShowcaseHero>

  <section class="page-section surface-light">
    <div class="container">
      <SectionIntro
        eyebrow="Arbeitsweise"
        title="Die Handschrift zeigt sich nicht in einer Stilmaske, sondern in konsistenter Wirkung."
        text="Positionierung vor Dekoration, Ruhe vor Lautstärke und ein Design, das auch auf realen Kontaktflächen funktioniert."
      />

      <div class="grid-3 reveal">
        <article class="proof-card">
          <h3>Positionierung vor Dekoration</h3>
          <p>Jede visuelle Entscheidung muss Markt- und Qualitätswahrnehmung stützen, nicht nur gefallen.</p>
        </article>
        <article class="proof-card">
          <h3>System statt Einzelbild</h3>
          <p>Website, Karte, Flyer oder Roll-up sollen wie Teile einer Linie wirken, nicht wie einzelne Zufallsstücke.</p>
        </article>
        <article class="proof-card">
          <h3>Premium ohne Distanz</h3>
          <p>Der Auftritt soll hochwertig, aber nicht überinszeniert sein. Klar, direkt und dauerhaft anschlussfähig.</p>
        </article>
      </div>
    </div>
  </section>

  <SelectiveComparison
    eyebrow="Was Fly & Froth verbessert"
    title="Die Arbeit zeigt sich am stärksten dort, wo vorher Unruhe oder Beliebigkeit sichtbar war."
    text="Die Beispiele stehen stellvertretend für die Grundlogik des Studios: mehr Ordnung, mehr Wirkung und ein sauber vorbereiteter Kontakt."
    items={comparisonItems}
  />

  <ContextualCTA
    title="Wenn Sie einen Partner suchen, der visuelle Qualität und Systemdenken wirklich verbindet, passt Fly & Froth genau zu dieser Aufgabe."
    text="Lassen Sie uns klären, wie Ihr Unternehmen digital hochwertiger, klarer und strukturierter auftreten kann."
    primaryHref={createContactHref({ entry_point: "about_cta", visual_context: "Über Fly & Froth" })}
    secondaryHref={whatsappHref}
  />
</BaseLayout>
