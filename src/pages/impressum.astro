---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { siteConfig } from "../data/site";
import { createBreadcrumbSchema } from "../utils/seo";

const breadcrumbs = [
  { name: "Start", href: "/" },
  { name: "Impressum", href: "/impressum" }
];
---

<BaseLayout
  title="Impressum | Fly & Froth"
  description="Impressum von Fly & Froth."
  pathname="/impressum"
  schema={[createBreadcrumbSchema(breadcrumbs)]}
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="page-section">
    <div class="container legal-shell">
      <div class="section-intro">
        <span class="eyebrow">Impressum</span>
        <h1>Angaben gemäß § 5 TMG</h1>
        <p>
          Dieses Impressum gilt für das Online-Angebot von Fly & Froth sowie für die damit verbundenen Kommunikations-
          und Anfragewege.
        </p>
      </div>

      <div class="card reveal">
        <h3>Anbieter</h3>
        <p>{siteConfig.legalName}</p>
        <p>{siteConfig.contact.addressLine1}</p>
        <p>{siteConfig.contact.postalCode} {siteConfig.contact.city}</p>
        <p>{siteConfig.contact.country}</p>

        <h3 class="legal-section-title">Kontakt</h3>
        <p>Telefon: <a class="text-link" href={`tel:${siteConfig.contact.phoneRaw}`}>{siteConfig.contact.phoneDisplay}</a></p>
        <p>E-Mail: <a class="text-link" href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a></p>
        <p>Website: <a class="text-link" href={siteConfig.siteUrl}>{siteConfig.siteUrl}</a></p>

        <h3 class="legal-section-title">Inhaltlich verantwortlich gemäß § 18 Abs. 2 MStV</h3>
        <p>
          Emrah
          <br />
          {siteConfig.contact.addressLine1}
          <br />
          {siteConfig.contact.postalCode} {siteConfig.contact.city}
        </p>

        <h3 class="legal-section-title">Haftung für Inhalte</h3>
        <p>
          Die Inhalte dieser Website werden mit größtmöglicher Sorgfalt erstellt. Eine Gewähr für Richtigkeit,
          Vollständigkeit und Aktualität der bereitgestellten Informationen wird jedoch nicht übernommen. Gesetzliche
          Verpflichtungen zur Entfernung oder Sperrung der Nutzung von Informationen bleiben hiervon unberührt.
        </p>

        <h3 class="legal-section-title">Haftung für Links</h3>
        <p>
          Diese Website enthält Verlinkungen zu externen Websites Dritter, insbesondere zu Diensten wie WhatsApp,
          Cal.com oder Social-Media-Plattformen. Auf deren Inhalte besteht kein Einfluss. Für die Inhalte verlinkter
          Seiten ist stets der jeweilige Betreiber verantwortlich.
        </p>

        <h3 class="legal-section-title">Urheberrecht</h3>
        <p>
          Alle durch Fly & Froth erstellten Inhalte, Gestaltungen, Texte, Bildkompositionen und Projektpräsentationen
          unterliegen dem deutschen Urheberrecht. Eine Nutzung, Vervielfältigung oder Bearbeitung außerhalb der
          gesetzlichen Grenzen bedarf der vorherigen schriftlichen Zustimmung.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
