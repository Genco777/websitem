---
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ContextualCTA from "../components/ContextualCTA.astro";
import PageShowcaseHero from "../components/PageShowcaseHero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ProjectGallery from "../components/ProjectGallery.astro";
import SectionIntro from "../components/SectionIntro.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { createBreadcrumbSchema, createServiceSchema } from "../utils/seo";
import { createContactHref, createWhatsappHref } from "../data/site";
import { curateVisualAssets, getProjectAssetsByIds, getProjectBySlug, getProjectGalleryAssets } from "../data/projects";

const breadcrumbs = [
  { name: "Start", href: "/" },
  { name: "Webdesign Frankfurt am Main", href: "/webdesign-frankfurt-am-main" }
];

const caremobil = getProjectBySlug("caremobil-greiz")!;
const conner = getProjectBySlug("conner-exteriors")!;
const meCon = getProjectBySlug("me-con")!;

const heroAssets = curateVisualAssets(
  [
    ...getProjectAssetsByIds(caremobil, ["caremobil-after-desktop", "caremobil-after-mobile"]),
    ...getProjectAssetsByIds(conner, ["conner-brand-applications-grid"]),
    ...getProjectAssetsByIds(meCon, ["me-con-expo-banner"])
  ],
  { count: 3, preferredVariants: ["wide_banner", "print_mockup", "device_mockup", "square_original"] }
);

const galleryImages = curateVisualAssets(
  [
    ...getProjectGalleryAssets(caremobil, 2),
    ...getProjectGalleryAssets(meCon, 2),
    ...getProjectGalleryAssets(conner, 1)
  ],
  { count: 4, preferredVariants: ["wide_banner", "print_mockup", "device_mockup", "detail_crop", "square_original"] }
);

const whatsappHref = createWhatsappHref("Hallo Fly & Froth, ich interessiere mich für Webdesign in Frankfurt am Main.");
---

<BaseLayout
  title="Webdesign Frankfurt am Main | Fly & Froth"
  description="Webdesign in Frankfurt am Main: hochwertige Websites, Markenauftritte und strukturierte Kontaktwege für lokale Unternehmen."
  pathname="/webdesign-frankfurt-am-main"
  schema={[
    createBreadcrumbSchema(breadcrumbs),
    createServiceSchema("Webdesign Frankfurt am Main", "Webdesign und Markenauftritte für Unternehmen aus Frankfurt am Main.")
  ]}
>
  <Breadcrumbs items={breadcrumbs} />

  <PageShowcaseHero
    eyebrow="Webdesign Frankfurt am Main"
    title="Webdesign in Frankfurt am Main für Unternehmen, die sichtbar souveräner auftreten wollen."
    text="Frankfurt ist visuell anspruchsvoll. Deshalb reicht eine ordentliche Website selten aus. Entscheidend ist ein Auftritt, der Kompetenz, Struktur und Markenqualität sofort glaubwürdig macht."
    actions={[
      { href: createContactHref({ entry_point: "seo_frankfurt", visual_context: "Frankfurt Landingpage" }), label: "Projekt anfragen" },
      { href: whatsappHref, label: "WhatsApp", style: "secondary", external: true }
    ]}
    stats={[
      { label: "Frankfurt", value: "starker Marktkontext" },
      { label: "Karben", value: "nah und direkt erreichbar" },
      { label: "Rhein-Main", value: "regional aufgebaut" }
    ]}
    images={heroAssets}
    tone="dark"
    layout="hero"
    badges={["Frankfurt", "Only Own Work"]}
  />

  <ProjectGallery
    eyebrow="Passende Beispiele"
    title="Für Frankfurt zählt nicht nur Sichtbarkeit, sondern auch gestalterische Souveränität."
    text="Die gezeigten Arbeiten verbinden wertigen Eindruck, präzise Struktur und einen sauberen Kontaktweg."
    images={galleryImages}
    maxItems={3}
  />

  <section class="page-section surface-light">
    <div class="container">
      <SectionIntro
        eyebrow="Was relevant wird"
        title="Webdesign für Frankfurt muss professionell, klar und belastbar wirken."
        text="Die Region ist wettbewerbsstark. Deshalb braucht ein guter Auftritt mehr als schöne Farben oder eine Standardstruktur."
      />

      <div class="grid-3 reveal">
        <article class="proof-card">
          <h3>Klarer erster Eindruck</h3>
          <p>Die Website muss sofort verständlich machen, worin Leistung, Qualität und nächster Schritt liegen.</p>
        </article>
        <article class="proof-card">
          <h3>Markenfähigkeit</h3>
          <p>Digitale und visuelle Mittel sollten dieselbe Linie tragen und nicht zufällig nebeneinanderstehen.</p>
        </article>
        <article class="proof-card">
          <h3>Strukturierte Leads</h3>
          <p>Kontakt, WhatsApp und Terminlogik müssen sinnvoll gebaut sein, damit Qualität im Prozess nicht verloren geht.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="page-section surface-dark">
    <div class="container">
      <SectionIntro
        eyebrow="Passende Referenzen"
        title="Drei Arbeiten, die für Frankfurt besonders anschlussfähig sind."
        text="Diese Projekte zeigen unterschiedliche Schwerpunkte, aber dieselbe Grundlogik: hochwertige Wirkung, saubere Struktur und klarer nächster Schritt."
      />

      <div class="project-card-grid reveal">
        {[meCon, caremobil, conner].map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </div>
  </section>

  <ContextualCTA
    title="Wenn Ihr Unternehmen in Frankfurt am Main digital deutlich souveräner wirken soll, ist das der richtige Einstieg."
    text="Fly & Froth verbindet klare Gestaltung, lokale Anschlussfähigkeit und strukturierte Kontaktlogik zu einem belastbaren Auftritt."
    primaryHref={createContactHref({ entry_point: "seo_frankfurt_cta", visual_context: "Frankfurt Landingpage" })}
    secondaryHref={whatsappHref}
  />
</BaseLayout>
